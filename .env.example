# This file serves as an example for the .env file.
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit your .env file to version control if it contains sensitive data.

# -----------------------------------------------------------------------------
# General Site Configuration
# -----------------------------------------------------------------------------
# Example: PUBLIC_SITE_URL="https://yourdomain.com"

# -----------------------------------------------------------------------------
# Blog & Project Features
# -----------------------------------------------------------------------------
# URL for your Google Calendar appointment scheduling page (if used)
PUBLIC_GOOGLE_CALENDAR_URL=""

# -----------------------------------------------------------------------------
# Contact Form & Email Configuration
# -----------------------------------------------------------------------------
# Gmail credentials for sending emails
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# The email address where contact form submissions will be sent
CONTACT_FORM_TO_EMAIL="your-email@example.com"

# -----------------------------------------------------------------------------
# Google Calendar Integration
# -----------------------------------------------------------------------------
# Google Service Account credentials for Calendar API
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"

# -----------------------------------------------------------------------------
# Other API Keys or Service Configurations (add as needed)
# -----------------------------------------------------------------------------
# Example: PUBLIC_ANALYTICS_ID="G-XXXXXXXXXX"

# -----------------------------------------------------------------------------
# Setup Instructions:
# -----------------------------------------------------------------------------
# 1. Gmail Setup:
#    - Enable 2FA on your Gmail account
#    - Generate an App Password: https://myaccount.google.com/apppasswords
#    - Use the App Password as EMAIL_PASS
#
# 2. Google Calendar Setup:
#    - Go to Google Cloud Console: https://console.cloud.google.com/
#    - Create a new project or select existing
#    - Enable Google Calendar API
#    - Create a Service Account
#    - Download the JSON key file
#    - Extract client_email and private_key from the JSON
#    - Create a calendar and share it with the service account email
#    - Use the calendar ID as GOOGLE_CALENDAR_ID
