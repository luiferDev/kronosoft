---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { buttonVariants } from '@/components/ui/button';
import { ArrowRight } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { LanguageCode } from '@/i18n/ui';

export type Props = {
  lang: LanguageCode;
  slug: string;
  title: string;
  imageUrl?: ImageMetadata;
  imageAltText: string;
  ctaText: string;
};

const { lang, slug, title, imageUrl, imageAltText, ctaText } = Astro.props;
const projectUrl = getRelativeLocaleUrl(lang, `/projects/${slug}`);
---

<a
  href={projectUrl}
  class="group relative block w-full h-80 md:h-96 rounded-lg overflow-hidden shadow-lg focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background featured-project-preview"
>
  {
    imageUrl ? (
      <Image
        src={imageUrl}
        alt={imageAltText}
        class="absolute inset-0 w-full h-full object-contain transition-transform duration-500 ease-in-out group-hover:scale-110"
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
        quality="mid"
      />
    ) : (
      <div class="absolute inset-0 w-full h-full bg-muted flex items-center justify-center">
        <p class="text-muted-foreground text-sm">
          {imageAltText || 'Image not available'}
        </p>
      </div>
    )
  }

  {/* Overlay content */}
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent p-6 flex flex-col justify-end"
  >
    <h3
      class="text-2xl md:text-3xl font-semibold text-primary-foreground dark:text-white/90 mb-2 transition-transform duration-300 ease-in-out md:group-hover:-translate-y-1"
    >
      {title}
    </h3>
    <div
      class="flex items-center text-sm font-medium text-primary-foreground dark:text-white/50 transition-opacity duration-300 ease-in-out transform opacity-100 translate-y-0 md:opacity-0 md:group-hover:opacity-100 md:translate-y-2 md:group-hover:translate-y-0"
    >
      {ctaText}
      <ArrowRight className="ml-2 size-4" />
    </div>
  </div>
</a>

<script is:inline>
  const enhanceFeaturedProjectHover = () => {
    const preview = document.querySelector('.featured-project-preview');
    if (!preview || typeof gsap === 'undefined') return;

    // Clean up any existing listeners to prevent duplicates
    preview.replaceWith(preview.cloneNode(true));
    
    // Get the new element after clone
    const newPreview = document.querySelector('.featured-project-preview');
    if (!newPreview) return;
    
    // Store tweens for cleanup
    const tweens: any[] = [];

    // Enhance the hover effect with GSAP
    newPreview.addEventListener('mouseenter', () => {
      const t1 = gsap.to(newPreview, {
        scale: 1.02,
        duration: 0.4,
        ease: 'power3.out',
      });
      tweens.push(t1);

      const title = newPreview.querySelector('h3');
      if (title) {
        const t2 = gsap.to(title, {
          y: -4,
          duration: 0.3,
          ease: 'power2.out',
        });
        tweens.push(t2);
      }

      const ctaDiv = newPreview.querySelector('.flex.items-center');
      if (ctaDiv) {
        const t3 = gsap.to(ctaDiv, {
          opacity: 1,
          y: 0,
          duration: 0.3,
          ease: 'power2.out',
        });
        tweens.push(t3);
      }
    });

    newPreview.addEventListener('mouseleave', () => {
      const t1 = gsap.to(newPreview, {
        scale: 1,
        duration: 0.4,
        ease: 'power3.out',
      });
      tweens.push(t1);

      const title = newPreview.querySelector('h3');
      if (title) {
        const t2 = gsap.to(title, {
          y: 0,
          duration: 0.3,
          ease: 'power2.out',
        });
        tweens.push(t2);
      }

      const ctaDiv = newPreview.querySelector('.flex.items-center');
      if (ctaDiv) {
        const t3 = gsap.to(ctaDiv, {
          opacity: 0.5,
          y: 4,
          duration: 0.3,
          ease: 'power2.out',
        });
        tweens.push(t3);
      }
    });
  };

  // Run after component mounts
  if (typeof document !== 'undefined') {
    if (document.readyState === 'loading') {
      document.addEventListener(
        'DOMContentLoaded',
        enhanceFeaturedProjectHover
      );
    } else {
      enhanceFeaturedProjectHover();
    }
  }
  
  // Re-run after Astro view transitions
  document.addEventListener('astro:after-swap', enhanceFeaturedProjectHover);
  
  // Clean up before navigation
  document.addEventListener('astro:before-preparation', () => {
    if (typeof gsap !== 'undefined') {
      gsap.killTweensOf('.featured-project-preview');
    }
  });
</script>
